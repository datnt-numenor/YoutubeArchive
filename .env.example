# App
SECRET_KEY=your-jwt-secret-key-min-32-chars
ENVIRONMENT=development
AUTH_COOKIE_NAME=ytarchive_session
AUTH_COOKIE_MAX_AGE_SECONDS=604800
# Set true when serving through HTTPS tunnel/domain.
AUTH_COOKIE_SECURE=false
# Required for public testing; comma-separate multiple admin emails.
ADMIN_EMAILS=you@example.com
REGISTRATION_INVITE_CODE=change-this-before-public-test

# Database
DATABASE_URL=sqlite+aiosqlite:///./ytarchive.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ytarchive

# Scheduler
SYNC_INTERVAL_HOURS=12

# yt-dlp anti-ban timing
YT_SLEEP_MIN_SECONDS=5
YT_SLEEP_MAX_SECONDS=15

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# S3 / Cloudflare R2
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=ytarchive-files
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PRESIGNED_URL_EXPIRY=3600

# Sentry
SENTRY_DSN=

# Local/default user quotas
DEFAULT_USER_EMAIL=local@example.com
DEFAULT_PLAYLIST_QUOTA=10
DEFAULT_STORAGE_QUOTA_GB=5
