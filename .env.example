# App
SECRET_KEY=your-jwt-secret-key-min-32-chars
ENVIRONMENT=development
AUTH_COOKIE_NAME=ytarchive_session
AUTH_COOKIE_MAX_AGE_SECONDS=604800
# Set true when serving through HTTPS tunnel/domain.
AUTH_COOKIE_SECURE=false
CSRF_COOKIE_NAME=ytarchive_csrf
CSRF_HEADER_NAME=x-csrf-token
APP_BASE_URL=http://127.0.0.1:8000
REQUIRE_EMAIL_VERIFICATION=false
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_RESET_TOKEN_MINUTES=30
EMAIL_VERIFICATION_TOKEN_HOURS=24
# Required for public testing; comma-separate multiple admin emails.
ADMIN_EMAILS=you@example.com
REGISTRATION_INVITE_CODE=change-this-before-public-test

# Database
DATABASE_URL=sqlite+aiosqlite:///./ytarchive.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ytarchive
# Run `alembic upgrade head` before starting with ENVIRONMENT=production.

# Scheduler
SYNC_INTERVAL_HOURS=12

# yt-dlp anti-ban timing
YT_SLEEP_MIN_SECONDS=5
YT_SLEEP_MAX_SECONDS=15

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
# Leave blank for local auto mode. Production defaults to celery when ENVIRONMENT=production.
# Set TASK_BACKEND=local only for private/dev single-process runs.
# TASK_BACKEND=celery
TASK_STATUS_TTL_SECONDS=86400

# S3 / Cloudflare R2
# Leave commented for local disk. Production with S3_BUCKET_NAME defaults to s3.
# STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=ytarchive-files
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PRESIGNED_URL_EXPIRY=3600

# Sentry
SENTRY_DSN=

# SMTP email for password reset and email verification.
# If omitted, email bodies are written to logs for private/dev testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Local/default user quotas
DEFAULT_USER_EMAIL=local@example.com
DEFAULT_PLAYLIST_QUOTA=10
DEFAULT_STORAGE_QUOTA_GB=5
