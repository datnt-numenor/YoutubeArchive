# ============================================================
# YoutubeArchive — Self-Host Environment (.env)
# Copy file này thành .env và điền giá trị thật vào.
# ============================================================

# --- App ---
ENVIRONMENT=production
SECRET_KEY=thay-bang-chuoi-ngau-nhien-toi-thieu-32-ky-tu
APP_BASE_URL=https://your-domain.com
AUTH_COOKIE_SECURE=true
REQUIRE_EMAIL_VERIFICATION=false
# Danh sách email admin, phân cách bằng dấu phẩy.
ADMIN_EMAILS=your-email@example.com
# Mã mời đăng ký — chỉ ai có mã mới đăng ký được.
REGISTRATION_INVITE_CODE=thay-bang-ma-moi-bi-mat

# --- Database (Neon PostgreSQL Free) ---
# Lấy connection string từ Neon Dashboard → Connection Details → chọn driver asyncpg.
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://ytarchive_owner:xxxx@ep-xxxx.us-east-2.aws.neon.tech/ytarchive?sslmode=require

# --- Redis (container local trong Docker Compose) ---
REDIS_URL=redis://redis:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=1
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=0.5

# --- Task Backend ---
TASK_BACKEND=celery
TASK_STATUS_TTL_SECONDS=86400

# --- Storage (Cloudflare R2 Free) ---
# Lấy từ Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create API Token.
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=ytarchive-files
S3_ACCESS_KEY_ID=thay-bang-r2-access-key
S3_SECRET_ACCESS_KEY=thay-bang-r2-secret-key
S3_PRESIGNED_URL_EXPIRY=3600

# --- Scheduler ---
SYNC_INTERVAL_HOURS=12

# --- yt-dlp anti-ban ---
YT_SLEEP_MIN_SECONDS=5
YT_SLEEP_MAX_SECONDS=15

# --- SMTP Email (tuỳ chọn) ---
# Nếu bỏ trống, email sẽ được ghi vào log thay vì gửi thật.
# Bạn có thể dùng Gmail App Password hoặc dịch vụ SMTP miễn phí.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# --- Quotas ---
DEFAULT_PLAYLIST_QUOTA=10
DEFAULT_STORAGE_QUOTA_GB=5

# --- Observability (tuỳ chọn) ---
SENTRY_DSN=
