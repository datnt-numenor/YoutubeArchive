# App
ENVIRONMENT=production
APP_BASE_URL=https://example.com
SECRET_KEY=replace-with-a-random-32-byte-minimum-secret
AUTH_COOKIE_SECURE=true
REQUIRE_EMAIL_VERIFICATION=true
ADMIN_EMAILS=admin@example.com
REGISTRATION_INVITE_CODE=replace-with-private-invite-code

# Database
DATABASE_URL=postgresql+asyncpg://ytarchive:change-this-postgres-password@127.0.0.1:5432/ytarchive

# Task backend
TASK_BACKEND=celery
REDIS_URL=redis://127.0.0.1:6379/0
TASK_STATUS_TTL_SECONDS=86400

# Storage
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET_NAME=ytarchive-files
S3_ACCESS_KEY_ID=replace-with-r2-access-key
S3_SECRET_ACCESS_KEY=replace-with-r2-secret-key
S3_PRESIGNED_URL_EXPIRY=3600

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=replace-with-smtp-user
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_USE_TLS=true

# Quotas
DEFAULT_PLAYLIST_QUOTA=10
DEFAULT_STORAGE_QUOTA_GB=5

# Observability
SENTRY_DSN=
